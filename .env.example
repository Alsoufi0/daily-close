DATABASE_URL="postgresql://postgres:postgres@localhost:5432/daily_close"

SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_REPORTS_BUCKET="pos-reports"

JWT_SECRET="replace-with-a-long-random-secret"
PORT="4000"

# API hardening
NODE_ENV="development"
# Comma-separated list of allowed CORS origins. Use "*" for any (dev only).
ALLOWED_ORIGINS="http://localhost:3000,https://daily-close-mvp.vercel.app"
# Expose Swagger /docs even when NODE_ENV=production.
ENABLE_SWAGGER="false"
# ALLOW_DEMO_AUTH was removed for security. Setting it to any value will
# refuse to boot the API (see apps/api/src/main.ts).

SITE_URL="https://daily-close-mvp.vercel.app"

# Subscriptions / Stripe (set these to enable self-serve checkout)
STRIPE_SECRET_KEY=""        # sk_live_... or sk_test_...
STRIPE_PRICE_ID=""          # price_... for the $29/store/month plan
# whsec_... from the Stripe dashboard (Developers → Webhooks → signing secret).
# REQUIRED in production: the /subscriptions/webhook route verifies every event
# against this secret and FAILS CLOSED (rejects all webhooks) when it is unset
# and NODE_ENV=production. Without it a forged POST could flip an owner to ACTIVE.
STRIPE_WEBHOOK_SECRET=""
STRIPE_PORTAL_URL=""        # optional: customer-portal link (Stripe dashboard)
STRIPE_CHECKOUT_URL=""      # legacy fallback only — leave blank when SECRET_KEY+PRICE_ID set

# OCR — Google Vision preferred when both keys are present (auto-detected)
GOOGLE_VISION_API_KEY=""
OCR_SPACE_API_KEY=""

# Weekly summary email (Resend)
RESEND_API_KEY=""
RESEND_FROM="Daily Close <reports@dailyclose.app>"

# Shared secret for cron endpoints (must match the value the cron sends)
CRON_SECRET=""

# WhatsApp Business Cloud API (optional — see whatsapp.service.ts for setup)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_TEMPLATE_MISSED="missed_close"
WHATSAPP_TEMPLATE_WEEKLY="weekly_summary"
WHATSAPP_TEMPLATE_MONTHLY="monthly_summary"
WHATSAPP_TEMPLATE_LANGUAGE="en_US"

# Twilio WhatsApp Content Template SIDs (HX…). Business-initiated WhatsApp
# alerts must be sent via an APPROVED template's ContentSid — freeform text is
# rejected by WhatsApp (error 63016). Create/approve these in the Twilio
# Content Template Builder, then paste the SID here. Also set TWILIO_WHATSAPP_FROM
# to your WhatsApp sender (e.g. +17042015710) and TWILIO_DELIVERY_CHANNEL=whatsapp.
TWILIO_TEMPLATE_CLOSE_COMPLETED=""

# Sentry error tracking. REQUIRED in production — the API refuses to boot
# when NODE_ENV=production and SENTRY_DSN is empty (see apps/api/src/main.ts).
# Optional in dev/staging.
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

# Optional dead-man monitor heartbeats for the cron jobs. Each cron pings
# its URL on success (fire-and-forget) so an external monitor
# (healthchecks.io / Better Stack / Uptime Kuma) can alert if a cron stops
# arriving. Leave empty to disable.
HEALTHCHECKS_MISSED_CLOSE_PING_URL=""
HEALTHCHECKS_WEEKLY_SUMMARY_PING_URL=""
HEALTHCHECKS_MONTHLY_SUMMARY_PING_URL=""

NEXT_PUBLIC_API_URL="https://your-api-host.example.com"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

EXPO_PUBLIC_API_URL="https://your-api-host.example.com"
EXPO_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
