DATABASE_URL="postgresql://postgres:postgres@localhost:5432/daily_close"

SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_REPORTS_BUCKET="pos-reports"

JWT_SECRET="replace-with-a-long-random-secret"
PORT="4000"

# API hardening
NODE_ENV="development"
# Comma-separated list of allowed CORS origins. Use "*" for any (dev only).
ALLOWED_ORIGINS="http://localhost:3000,https://daily-close-mvp.vercel.app"
# Expose Swagger /docs even when NODE_ENV=production.
ENABLE_SWAGGER="false"
# Enable demo header auth (x-demo-role: owner|employee). Never enable in production.
ALLOW_DEMO_AUTH="false"

# Subscriptions / Stripe (optional - set when you wire billing)
STRIPE_CHECKOUT_URL=""
STRIPE_PORTAL_URL=""
STRIPE_WEBHOOK_SECRET=""

# Sentry error tracking (optional - leave empty to disable)
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

NEXT_PUBLIC_API_URL="https://your-api-host.example.com"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

EXPO_PUBLIC_API_URL="https://your-api-host.example.com"
EXPO_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
