generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  STORE_OWNER
  EMPLOYEE

  @@map("user_role")
}

// Per-(user, store) assignment role on the `employees` table.
// OWNER rows are auto-created when a store is created so we can answer
// "is user X allowed to close store Y?" via a single uniform query
// regardless of whether X owns Y or works at Y.
enum EmployeeRole {
  OWNER
  EMPLOYEE
  MANAGER

  @@map("employee_role")
}

enum CloseStatus {
  PENDING
  CLOSED
  SHORT
  OVER

  @@map("close_status")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ

  @@map("notification_status")
}

enum NotificationType {
  PUSH
  EMAIL
  SMS

  @@map("notification_type")
}

// Lifecycle of a row in the partner payout ledger.
enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  REVERSED

  @@map("commission_status")
}

// COMMISSION rows are auto-minted from a Stripe invoice. ADJUSTMENT rows are
// entered by an admin (bonus = positive, clawback = negative amount).
enum CommissionKind {
  COMMISSION
  ADJUSTMENT

  @@map("commission_kind")
}

model User {
  id              String         @id @default(cuid())
  authUserId      String?        @unique @map("auth_user_id")
  name            String
  email           String         @unique
  password        String
  role            UserRole
  createdAt       DateTime       @default(now()) @map("created_at")
  owner           Owner?
  // `employees` is now a list (was single Employee?) — a single user can
  // be assigned to many stores. See migration 006_store_assignments.sql.
  employees       Employee[]
  // Closes this user has submitted, captured via daily_close.submitted_by_user_id.
  // Stored separately from the employee FK so owner-closes don't need a
  // synthesised employee row.
  submittedCloses DailyClose[]   @relation("DailyCloseSubmittedBy")
  uploadedReports UploadedReport[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  attestedConsents PhoneConsent[] @relation("PhoneConsentAttester")

  @@map("users")
}

model Owner {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  subscriptionPlan     String    @default("MVP") @map("subscription_plan")
  subscriptionStatus   String    @default("TRIALING") @map("subscription_status")
  trialEndsAt          DateTime? @map("trial_ends_at")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  // First-touch referral attribution: the partner whose QR/link this owner
  // signed up through. Stamped ONCE at signup, never reassigned (the API only
  // writes it when it is currently null). See migration 011.
  referredByPartnerId  String?   @map("referred_by_partner_id")
  user                 User      @relation(fields: [userId], references: [id])
  referredBy           Partner?  @relation(fields: [referredByPartnerId], references: [id])
  stores               Store[]
  commissions          Commission[]

  @@index([referredByPartnerId])
  @@map("owners")
}

// `employees` rows are STORE ASSIGNMENTS: one row per (user, store, role).
// One user can have many rows — one per store they're assigned to. Role
// distinguishes OWNER (auto-created with the store) from EMPLOYEE (invited
// by an owner). Composite uniqueness on (user_id, store_id) prevents
// duplicate assignments, but a user CAN appear on many stores.
//
// See migration 006_store_assignments.sql for the constraint reshape.
model Employee {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  storeId     String       @map("store_id")
  role        EmployeeRole @default(EMPLOYEE)
  deletedAt   DateTime?    @map("deleted_at")
  user        User         @relation(fields: [userId], references: [id])
  store       Store        @relation(fields: [storeId], references: [id])
  dailyCloses DailyClose[]
  phoneConsents PhoneConsent[]

  @@unique([userId, storeId], map: "employees_user_store_uniq")
  @@index([userId])
  @@index([deletedAt])
  @@map("employees")
}

model Store {
  id            String         @id @default(cuid())
  ownerId       String         @map("owner_id")
  storeName     String         @map("store_name")
  address       String?
  phone         String?
  timezone      String         @default("America/New_York")
  closeTime     String         @default("23:30") @map("close_time")
  deletedAt     DateTime?      @map("deleted_at")
  // When set, the store is PAUSED: excluded from billing (not counted toward the
  // Stripe quantity) and not closeable, but its data/history is retained and it
  // can be resumed any time. Null = active (billed). Existing stores stay null.
  pausedAt      DateTime?      @map("paused_at")
  owner         Owner          @relation(fields: [ownerId], references: [id])
  employees     Employee[]
  dailyCloses   DailyClose[]
  expenses      Expense[]
  uploadedReports UploadedReport[]
  notifications Notification[]
  auditLogs     AuditLog[]
  phoneConsents PhoneConsent[]

  @@index([ownerId])
  @@index([deletedAt])
  @@index([pausedAt])
  @@map("stores")
}

model DailyClose {
  id                String           @id @default(cuid())
  idempotencyKey    String?          @unique @map("idempotency_key")
  storeId           String           @map("store_id")
  // employeeId is now nullable — owner-closes don't synthesise a fake
  // employee row anymore. Old rows keep their link; new rows may set
  // null and rely on submittedByUserId for "who closed it".
  employeeId        String?          @map("employee_id")
  // Always set on new closes via migration 006. Source of truth for
  // "who actually submitted this close" regardless of role.
  submittedByUserId String           @map("submitted_by_user_id")
  // Stored as a full timestamp (timestamptz), NOT a date-only value. The
  // close-guard and dashboard compute store-local day boundaries as UTC
  // instants and range-query against this column; a date-only type made
  // Postgres truncate the bounds and falsely match a prior day's close.
  // Migration 007 converts the legacy `date` column to timestamptz.
  date              DateTime         @db.Timestamptz(3)
  cashSales         Decimal          @map("cash_sales") @db.Decimal(12, 2)
  cardSales         Decimal          @map("card_sales") @db.Decimal(12, 2)
  totalSales        Decimal          @map("total_sales") @db.Decimal(12, 2)
  tax               Decimal          @default(0) @db.Decimal(12, 2)
  refunds           Decimal          @default(0) @db.Decimal(12, 2)
  discounts         Decimal          @default(0) @db.Decimal(12, 2)
  lottery           Decimal?         @db.Decimal(12, 2)
  expectedCash      Decimal          @map("expected_cash") @db.Decimal(12, 2)
  countedCash       Decimal          @map("counted_cash") @db.Decimal(12, 2)
  difference        Decimal          @db.Decimal(12, 2)
  expenses          Decimal          @default(0) @db.Decimal(12, 2)
  notes             String?
  status            CloseStatus
  createdAt         DateTime         @default(now()) @map("created_at")
  store             Store            @relation(fields: [storeId], references: [id])
  employee          Employee?        @relation(fields: [employeeId], references: [id])
  submittedBy       User             @relation("DailyCloseSubmittedBy", fields: [submittedByUserId], references: [id])
  expenseItems      Expense[]
  uploadedReports   UploadedReport[]

  @@unique([storeId, date])
  @@index([storeId, date])
  @@index([employeeId])
  @@map("daily_close")
}

model Expense {
  id           String      @id @default(cuid())
  storeId      String      @map("store_id")
  dailyCloseId String?     @map("daily_close_id")
  amount       Decimal     @db.Decimal(12, 2)
  category     String
  description  String?
  createdAt    DateTime    @default(now()) @map("created_at")
  store        Store       @relation(fields: [storeId], references: [id])
  dailyClose   DailyClose? @relation(fields: [dailyCloseId], references: [id])

  @@index([storeId])
  @@map("expenses")
}

model UploadedReport {
  id                 String      @id @default(cuid())
  dailyCloseId       String?     @map("daily_close_id")
  storeId            String?     @map("store_id")
  uploadedByUserId   String?     @map("uploaded_by_user_id")
  imageUrl           String      @map("image_url")
  // Storage object path (bucket-relative) so the API can re-sign the URL
  // on demand. image_url's signed URL expires after 7 days; storagePath
  // never does. Nullable for rows uploaded before migration 009.
  storagePath        String?     @map("storage_path")
  parsedJson         Json        @map("parsed_json")
  parserType         String      @map("parser_type")
  createdAt          DateTime    @default(now()) @map("created_at")
  dailyClose         DailyClose? @relation(fields: [dailyCloseId], references: [id])
  store              Store?      @relation(fields: [storeId], references: [id])
  uploadedBy         User?       @relation(fields: [uploadedByUserId], references: [id])

  @@index([dailyCloseId])
  @@index([storeId])
  @@index([uploadedByUserId])
  @@index([createdAt(sort: Desc)])
  @@map("uploaded_reports")
}

model Notification {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  storeId   String?            @map("store_id")
  type      NotificationType
  message   String
  status    NotificationStatus @default(PENDING)
  createdAt DateTime           @default(now()) @map("created_at")
  user      User               @relation(fields: [userId], references: [id])
  store     Store?             @relation(fields: [storeId], references: [id])

  @@index([userId, status])
  @@map("notifications")
}

// Twilio A2P 10DLC compliance — audit trail of who consented to SMS,
// when, and what they were shown. One row per consent event. STOP-replies
// flip `opted_out_at` rather than deleting the row so the audit trail
// stays intact. See migration 010_phone_consents.sql.
model PhoneConsent {
  id                  String    @id @default(cuid())
  phone               String
  employeeId          String?   @map("employee_id")
  consentedByUserId   String    @map("consented_by_user_id")
  storeId             String    @map("store_id")
  consentMethod       String    @map("consent_method")
  consentText         String    @map("consent_text")
  consentedAt         DateTime  @default(now()) @map("consented_at")
  optedOutAt          DateTime? @map("opted_out_at")
  employee            Employee? @relation(fields: [employeeId], references: [id])
  consentedBy         User      @relation("PhoneConsentAttester", fields: [consentedByUserId], references: [id])
  store               Store     @relation(fields: [storeId], references: [id])

  @@index([phone])
  @@index([employeeId])
  @@map("phone_consents")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storeId   String?  @map("store_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])
  store     Store?   @relation(fields: [storeId], references: [id])

  @@index([userId, createdAt])
  @@index([storeId, createdAt])
  @@map("audit_logs")
}

// A sales distributor who refers store owners via a QR/link and earns a
// recurring % while a referred owner keeps paying. See migration 011.
model Partner {
  id             String       @id @default(cuid())
  name           String
  contact        String?
  payoutDetails  String?      @map("payout_details")
  // Short, random, non-sequential, no ambiguous chars (no O/0/I/1). Generated
  // once on create in the API; never regenerated.
  refCode        String       @unique @map("ref_code")
  // Per-partner override of the platform default rate. Null = use the default
  // from AppSetting at the time a commission is created.
  commissionRate Decimal?     @map("commission_rate") @db.Decimal(5, 4)
  active         Boolean      @default(true)
  // Raw QR/link visit count (top of funnel). Not deduplicated.
  scanCount      Int          @default(0) @map("scan_count")
  createdAt      DateTime     @default(now()) @map("created_at")
  referredOwners Owner[]
  commissions    Commission[]

  @@map("partners")
}

// One row in the payout ledger. COMMISSION rows are minted from a real Stripe
// invoice payment; ADJUSTMENT rows are entered by an admin for bonuses /
// clawbacks so the ledger reconciles. Driven by payment events, never by
// subscription status.
model Commission {
  id                String           @id @default(cuid())
  partnerId         String           @map("partner_id")
  // Set for COMMISSION rows (the paying account); null for partner-level
  // ADJUSTMENT rows.
  ownerId           String?          @map("owner_id")
  // The Stripe invoice that triggered this row (COMMISSION only). Unique so
  // webhook retries are idempotent. Null for ADJUSTMENT rows.
  stripeInvoiceId   String?          @unique @map("stripe_invoice_id")
  // Billing period label, e.g. "2026-06", for grouping the payout queue.
  period            String
  // Snapshot of the rate applied, so later rate changes never rewrite history.
  rate              Decimal          @db.Decimal(5, 4)
  // Commission amount in `currency`. Negative for an ADJUSTMENT clawback.
  amount            Decimal          @db.Decimal(12, 2)
  currency          String           @default("usd")
  // The invoice amount (cents) this was computed from — reconciliation aid.
  sourceAmountCents Int?             @map("source_amount_cents")
  status            CommissionStatus @default(PENDING)
  kind              CommissionKind   @default(COMMISSION)
  note              String?
  payoutReference   String?          @map("payout_reference")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at")
  partner           Partner          @relation(fields: [partnerId], references: [id])
  owner             Owner?           @relation(fields: [ownerId], references: [id])

  @@index([partnerId, status])
  @@index([ownerId])
  @@index([period])
  @@map("commissions")
}

// Single-row platform settings (id is always "global"). Holds the default
// commission rate applied when a partner has no per-partner override.
model AppSetting {
  id                    String   @id @default("global")
  defaultCommissionRate Decimal  @default(0.25) @map("default_commission_rate") @db.Decimal(5, 4)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("app_settings")
}
