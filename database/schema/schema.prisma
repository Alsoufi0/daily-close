generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  STORE_OWNER
  EMPLOYEE

  @@map("user_role")
}

// Per-(user, store) assignment role on the `employees` table.
// OWNER rows are auto-created when a store is created so we can answer
// "is user X allowed to close store Y?" via a single uniform query
// regardless of whether X owns Y or works at Y.
enum EmployeeRole {
  OWNER
  EMPLOYEE
  MANAGER

  @@map("employee_role")
}

enum CloseStatus {
  PENDING
  CLOSED
  SHORT
  OVER

  @@map("close_status")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ

  @@map("notification_status")
}

enum NotificationType {
  PUSH
  EMAIL
  SMS

  @@map("notification_type")
}

model User {
  id              String         @id @default(cuid())
  authUserId      String?        @unique @map("auth_user_id")
  name            String
  email           String         @unique
  password        String
  role            UserRole
  createdAt       DateTime       @default(now()) @map("created_at")
  owner           Owner?
  // `employees` is now a list (was single Employee?) — a single user can
  // be assigned to many stores. See migration 006_store_assignments.sql.
  employees       Employee[]
  // Closes this user has submitted, captured via daily_close.submitted_by_user_id.
  // Stored separately from the employee FK so owner-closes don't need a
  // synthesised employee row.
  submittedCloses DailyClose[]   @relation("DailyCloseSubmittedBy")
  uploadedReports UploadedReport[]
  notifications   Notification[]
  auditLogs       AuditLog[]

  @@map("users")
}

model Owner {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  subscriptionPlan     String    @default("MVP") @map("subscription_plan")
  subscriptionStatus   String    @default("TRIALING") @map("subscription_status")
  trialEndsAt          DateTime? @map("trial_ends_at")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  user                 User      @relation(fields: [userId], references: [id])
  stores               Store[]

  @@map("owners")
}

// `employees` rows are STORE ASSIGNMENTS: one row per (user, store, role).
// One user can have many rows — one per store they're assigned to. Role
// distinguishes OWNER (auto-created with the store) from EMPLOYEE (invited
// by an owner). Composite uniqueness on (user_id, store_id) prevents
// duplicate assignments, but a user CAN appear on many stores.
//
// See migration 006_store_assignments.sql for the constraint reshape.
model Employee {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  storeId     String       @map("store_id")
  role        EmployeeRole @default(EMPLOYEE)
  deletedAt   DateTime?    @map("deleted_at")
  user        User         @relation(fields: [userId], references: [id])
  store       Store        @relation(fields: [storeId], references: [id])
  dailyCloses DailyClose[]

  @@unique([userId, storeId], map: "employees_user_store_uniq")
  @@index([userId])
  @@index([deletedAt])
  @@map("employees")
}

model Store {
  id            String         @id @default(cuid())
  ownerId       String         @map("owner_id")
  storeName     String         @map("store_name")
  address       String?
  phone         String?
  timezone      String         @default("America/New_York")
  closeTime     String         @default("23:30") @map("close_time")
  deletedAt     DateTime?      @map("deleted_at")
  owner         Owner          @relation(fields: [ownerId], references: [id])
  employees     Employee[]
  dailyCloses   DailyClose[]
  expenses      Expense[]
  uploadedReports UploadedReport[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([ownerId])
  @@index([deletedAt])
  @@map("stores")
}

model DailyClose {
  id                String           @id @default(cuid())
  idempotencyKey    String?          @unique @map("idempotency_key")
  storeId           String           @map("store_id")
  // employeeId is now nullable — owner-closes don't synthesise a fake
  // employee row anymore. Old rows keep their link; new rows may set
  // null and rely on submittedByUserId for "who closed it".
  employeeId        String?          @map("employee_id")
  // Always set on new closes via migration 006. Source of truth for
  // "who actually submitted this close" regardless of role.
  submittedByUserId String           @map("submitted_by_user_id")
  // Stored as a full timestamp (timestamptz), NOT a date-only value. The
  // close-guard and dashboard compute store-local day boundaries as UTC
  // instants and range-query against this column; a date-only type made
  // Postgres truncate the bounds and falsely match a prior day's close.
  // Migration 007 converts the legacy `date` column to timestamptz.
  date              DateTime         @db.Timestamptz(3)
  cashSales         Decimal          @map("cash_sales") @db.Decimal(12, 2)
  cardSales         Decimal          @map("card_sales") @db.Decimal(12, 2)
  totalSales        Decimal          @map("total_sales") @db.Decimal(12, 2)
  tax               Decimal          @default(0) @db.Decimal(12, 2)
  refunds           Decimal          @default(0) @db.Decimal(12, 2)
  discounts         Decimal          @default(0) @db.Decimal(12, 2)
  lottery           Decimal?         @db.Decimal(12, 2)
  expectedCash      Decimal          @map("expected_cash") @db.Decimal(12, 2)
  countedCash       Decimal          @map("counted_cash") @db.Decimal(12, 2)
  difference        Decimal          @db.Decimal(12, 2)
  expenses          Decimal          @default(0) @db.Decimal(12, 2)
  notes             String?
  status            CloseStatus
  createdAt         DateTime         @default(now()) @map("created_at")
  store             Store            @relation(fields: [storeId], references: [id])
  employee          Employee?        @relation(fields: [employeeId], references: [id])
  submittedBy       User             @relation("DailyCloseSubmittedBy", fields: [submittedByUserId], references: [id])
  expenseItems      Expense[]
  uploadedReports   UploadedReport[]

  @@unique([storeId, date])
  @@index([storeId, date])
  @@index([employeeId])
  @@map("daily_close")
}

model Expense {
  id           String      @id @default(cuid())
  storeId      String      @map("store_id")
  dailyCloseId String?     @map("daily_close_id")
  amount       Decimal     @db.Decimal(12, 2)
  category     String
  description  String?
  createdAt    DateTime    @default(now()) @map("created_at")
  store        Store       @relation(fields: [storeId], references: [id])
  dailyClose   DailyClose? @relation(fields: [dailyCloseId], references: [id])

  @@index([storeId])
  @@map("expenses")
}

model UploadedReport {
  id                 String      @id @default(cuid())
  dailyCloseId       String?     @map("daily_close_id")
  storeId            String?     @map("store_id")
  uploadedByUserId   String?     @map("uploaded_by_user_id")
  imageUrl           String      @map("image_url")
  parsedJson         Json        @map("parsed_json")
  parserType         String      @map("parser_type")
  createdAt          DateTime    @default(now()) @map("created_at")
  dailyClose         DailyClose? @relation(fields: [dailyCloseId], references: [id])
  store              Store?      @relation(fields: [storeId], references: [id])
  uploadedBy         User?       @relation(fields: [uploadedByUserId], references: [id])

  @@index([dailyCloseId])
  @@index([storeId])
  @@index([uploadedByUserId])
  @@index([createdAt(sort: Desc)])
  @@map("uploaded_reports")
}

model Notification {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  storeId   String?            @map("store_id")
  type      NotificationType
  message   String
  status    NotificationStatus @default(PENDING)
  createdAt DateTime           @default(now()) @map("created_at")
  user      User               @relation(fields: [userId], references: [id])
  store     Store?             @relation(fields: [storeId], references: [id])

  @@index([userId, status])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storeId   String?  @map("store_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])
  store     Store?   @relation(fields: [storeId], references: [id])

  @@index([userId, createdAt])
  @@index([storeId, createdAt])
  @@map("audit_logs")
}
