{
  "name": "daily-close",
  "private": true,
  "version": "0.1.0",
  "description": "Daily Close MVP monorepo",
  "workspaces": [
    "apps/api",
    "apps/web",
    "apps/mobile",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run start:dev --workspace apps/api",
    "dev:mobile": "npm run start --workspace apps/mobile",
    "build": "npm run build --workspace apps/web && npm run build --workspace apps/api",
    "typecheck": "npm run typecheck --workspace apps/web && npm run typecheck --workspace apps/api && npm run typecheck --workspace apps/mobile",
    "prisma:generate": "prisma generate --schema database/schema/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "regenerator-runtime": "^0.14.1"
  }
}
