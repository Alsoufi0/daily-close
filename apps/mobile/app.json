{
  "expo": {
    "name": "Daily Close",
    "slug": "daily-close",
    "owner": "daily-closes-team",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "dailyclose",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0e3b34"
    },
    "ios": {
      "bundleIdentifier": "com.dailyclose1.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Employees take a photo of the POS report to fill daily closing numbers.",
        "NSPhotoLibraryUsageDescription": "Employees can upload a POS report image from their phone.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": [
          "en",
          "es",
          "ar",
          "hi"
        ]
      }
    },
    "locales": {
      "en": "./locales/en.json",
      "es": "./locales/es.json",
      "ar": "./locales/ar.json",
      "hi": "./locales/hi.json"
    },
    "android": {
      "package": "us.dailyclose.app",
      "versionCode": 9,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e3b34"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      "expo-image-picker",
      "expo-secure-store",
      "@sentry/react-native/expo",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "3bf4a9e8-3ec5-42c7-b7d1-71b37185f4b4"
      }
    }
  }
}
